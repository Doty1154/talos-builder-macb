CONFIG_TXT="dtoverlay=disable-wifi
dtoverlay=disable-bt
dtoverlay=vc4-kms-v3d
disable_fw_kms_setup=1
dtparam=pciex1
dtparam=pciex1_gen=3
dtparam=audio=off
PCIE_PROBE=1 
dtoverlay=dwc2,dr_mode=host
dtparam=i2c_arm=on
dtparam=spi=on
display_auto_detect=1
dtoverlay=rpi-poe
dtparam=poe_fan_temp0=70000,poe_fan_temp0_hyst=1000
dtparam=poe_fan_temp1=75000,poe_fan_temp1_hyst=5000
"

#Required for Longhorn CSI
EXTENSIONS="ghcr.io/siderolabs/btrfs:v1.13.0 ghcr.io/siderolabs/crun:1.27.1 ghcr.io/siderolabs/ctr:v2.3.0 ghcr.io/siderolabs/fuse3:3.18.2 ghcr.io/siderolabs/iscsi-tools:v0.2.0 ghcr.io/siderolabs/mdadm:v4.6 ghcr.io/siderolabs/nfs-utils:v0.1.1 ghcr.io/siderolabs/nfsd:v1.13.0 ghcr.io/siderolabs/nfsahead:2.8.3 ghcr.io/siderolabs/nvme-cli:v2.14 ghcr.io/siderolabs/realtek-firmware:20260410 ghcr.io/siderolabs/tailscale:1.96.4 ghcr.io/siderolabs/util-linux-tools:2.42.0 ghcr.io/siderolabs/vc4:v1.13.0"
TALOS_VERSION=v1.13.0
#Artifacts must be pushed to a registry during build
# docker run -d -p 5000 --restart always --name local registry:3
REGISTRY=registry:5000
REGISTRY_USERNAME=talos-pi5
